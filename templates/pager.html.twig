{#
/**
 * @file
 * pager.html.twig
 * Luna Theme — Bootstrap pagination component.
 */
#}
{% if items %}
  <nav class="pager" role="navigation" aria-label="{{ 'Pagination'|t }}">
    <ul class="pagination justify-content-center">

      {# First page #}
      {% if items.first %}
        <li class="page-item">
          <a class="page-link" href="{{ items.first.href }}"
             title="{{ 'Go to first page'|t }}"{{ items.first.attributes }}>
            &laquo;
          </a>
        </li>
      {% endif %}

      {# Previous page #}
      {% if items.previous %}
        <li class="page-item">
          <a class="page-link" href="{{ items.previous.href }}"
             title="{{ 'Go to previous page'|t }}"
             rel="prev"{{ items.previous.attributes }}>
            &lsaquo;
          </a>
        </li>
      {% endif %}

      {# Numbered pages #}
      {% if items.pages %}
        {% for key, item in items.pages %}
          <li class="page-item {% if current == key %}active{% endif %}">
            {% if current == key %}
              <span class="page-link" aria-current="page"
                    aria-label="{{ 'Current page'|t }}, {{ 'Page'|t }} {{ key }}">
                {{ key }}
              </span>
            {% else %}
              <a class="page-link" href="{{ item.href }}"
                 aria-label="{{ 'Page'|t }} {{ key }}"{{ item.attributes }}>
                {{ key }}
              </a>
            {% endif %}
          </li>
        {% endfor %}
      {% endif %}

      {# Next page #}
      {% if items.next %}
        <li class="page-item">
          <a class="page-link" href="{{ items.next.href }}"
             title="{{ 'Go to next page'|t }}"
             rel="next"{{ items.next.attributes }}>
            &rsaquo;
          </a>
        </li>
      {% endif %}

      {# Last page #}
      {% if items.last %}
        <li class="page-item">
          <a class="page-link" href="{{ items.last.href }}"
             title="{{ 'Go to last page'|t }}"{{ items.last.attributes }}>
            &raquo;
          </a>
        </li>
      {% endif %}

    </ul>
  </nav>
{% endif %}
