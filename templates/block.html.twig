{#
/**
 * @file
 * block.html.twig
 * Luna Theme — Block wrapper template.
 */
#}
<div{{ attributes.addClass('block', 'block-' ~ configuration.provider|clean_class, 'block-' ~ plugin_id|clean_class) }}>
  {% block content %}
    {{ title_prefix }}
    {% if label %}
      <h2{{ title_attributes.addClass('block-title', 'h6', 'fw-bold', 'text-uppercase', 'mb-3') }}
          style="font-size:.75rem;letter-spacing:.1em;color:var(--bs-secondary-color);">
        {{ label }}
      </h2>
    {% endif %}
    {{ title_suffix }}
    {{ content }}
  {% endblock %}
</div>
