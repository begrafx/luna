{#
/**
 * @file
 * views-view-unformatted.html.twig
 * Luna Theme — Unformatted views rows in a Bootstrap responsive grid.
 */
#}
{% if title %}
  <h3 class="h4 mb-4">{{ title }}</h3>
{% endif %}
{% if rows %}
  <div class="row g-4">
    {% for row in rows %}
      <div class="col-sm-6 col-lg-4">
        {{ row.content }}
      </div>
    {% endfor %}
  </div>
{% endif %}
