{#
/**
 * @file
 * block--block-content--hero.html.twig
 * Luna Theme — Hero block template.
 *
 * Renders a block_content entity of bundle "hero" as a full-width
 * Luna hero section with optional background image support.
 *
 * Variables provided by:
 * luna_preprocess_block__block_content() in luna.theme
 *
 * Available variables:
 *
 *   hero_heading      — Hero title (safe HTML allowed)
 *   hero_subheading   — Supporting text
 *   hero_cta_text     — CTA button label
 *   hero_cta_url      — CTA destination URL
 *   hero_style        — gradient | dark | light
 *   hero_image_url    — Full background image URL
 *
 * To manage this content:
 * Structure → Block layout → Custom block library
 */
#}

{% set style = hero_style|default('gradient') %}

<section
  class="luna-hero luna-hero--{{ style }}
  {% if hero_image_url %} luna-hero--image{% endif %}"
  aria-label="{{ 'Hero'|t }}"
  {% if hero_image_url %}
    style="background-image:url('{{ hero_image_url }}');"
  {% endif %}
  {{ attributes }}
>

  {# Decorative grid overlay #}
  <div class="luna-hero__grid-pattern" aria-hidden="true"></div>

  <div class="container-xl">
    <div class="row align-items-center">

      {# ── Hero Content ───────────────────────────────────── #}
      <div class="col-lg-8 col-xl-7">

        <div class="luna-hero__content">

          {% if hero_eyebrow %}
            <span class="luna-hero__eyebrow">
              {{ hero_eyebrow }}
            </span>
          {% endif %}

          {% if hero_heading %}
            <h1 class="luna-hero__title">
              {{ hero_heading|raw }}
            </h1>
          {% endif %}

          {% if hero_subheading %}
            <p class="luna-hero__subtitle">
              {{ hero_subheading }}
            </p>
          {% endif %}

          {% if hero_cta_text and hero_cta_url %}
            <div class="luna-hero__actions">

              <a href="{{ hero_cta_url }}"
                 class="btn btn-lg btn-gradient">

                {{ hero_cta_text }}

                <svg xmlns="http://www.w3.org/2000/svg"
                     width="16"
                     height="16"
                     fill="currentColor"
                     class="ms-2"
                     viewBox="0 0 16 16"
                     aria-hidden="true">

                  <path fill-rule="evenodd"
                        d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
                </svg>

              </a>

            </div>
          {% endif %}

        </div>{# /.luna-hero__content #}

      </div>{# /.col #}

    </div>{# /.row #}
  </div>{# /.container-xl #}

  {# Scroll indicator #}
  <a href="#main-content"
     class="luna-hero__scroll"
     aria-label="{{ 'Scroll down'|t }}">

    <span class="luna-hero__scroll-arrow"
          aria-hidden="true"></span>

    <span>{{ 'Scroll'|t }}</span>

  </a>

</section>