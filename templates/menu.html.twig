{#
/**
 * @file
 * menu.html.twig
 * Luna Theme — Navigation menu using Bootstrap/Halfmoon nav classes.
 */
#}

{% import _self as menus %}

{{ menus.menu_links(items, attributes, 0) }}

{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes.addClass('navbar-nav', 'flex-row', 'flex-wrap', 'align-items-center') }}>
    {% else %}
      <ul class="dropdown-menu">
    {% endif %}
    {% for item in items %}
      {% set classes = ['nav-item'] %}
      {% if item.is_expanded and item.below %}
        {% set classes = classes|merge(['dropdown']) %}
      {% endif %}
      <li{{ item.attributes.addClass(classes) }}>
        {% if menu_level == 0 %}
          {% if item.is_expanded and item.below %}
            <a{{ item.link.attributes
                  .addClass('nav-link', 'dropdown-toggle')
                  .setAttribute('data-bs-toggle', 'dropdown')
                  .setAttribute('aria-expanded', 'false') }}>
              {{ item.title }}
            </a>
            {{ menus.menu_links(item.below, attributes.removeClass('navbar-nav'), menu_level + 1) }}
          {% else %}
            <a{{ item.link.attributes.addClass('nav-link', item.in_active_trail ? 'active') }}>
              {{ item.title }}
            </a>
          {% endif %}
        {% else %}
          {% if item.is_expanded and item.below %}
            <a{{ item.link.attributes
                  .addClass('dropdown-item', 'dropdown-toggle')
                  .setAttribute('data-bs-toggle', 'dropdown') }}>
              {{ item.title }}
            </a>
            {{ menus.menu_links(item.below, attributes.removeClass('navbar-nav'), menu_level + 1) }}
          {% else %}
            <a{{ item.link.attributes.addClass('dropdown-item', item.in_active_trail ? 'active') }}>
              {{ item.title }}
            </a>
          {% endif %}
        {% endif %}
      </li>
    {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}
